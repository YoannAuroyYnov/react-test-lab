{
  "name": "@yoann-86/react_test_lab",
  "version": "0.1.1",
  "private": false,
  "homepage": "https://yoannauroyynov.github.io/react-test-lab/",
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.13.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4",
    "wouter": "^3.9.0"
  },
  "scripts": {
    "adduser": "login",
    "cypress": "cypress open",
    "start": "react-scripts start",
    "build": "react-scripts build",
    "build:npm": "NODE_ENV=production && rm -rf dist && mkdir dist && npx babel src --out-dir dist --copy-files",
    "jsdoc": "jsdoc -R ./README.md -c ./jsdoc.config.json -r -d ./public/docs",
    "test": "react-scripts test --coverage --collectCoverageFrom=!src/reportWebVitals.js --collectCoverageFrom=!src/index.js --watchAll=false",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-react-jsx": "^7.28.6",
    "cypress": "^15.10.0",
    "jsdoc": "^4.0.5",
    "react-test-renderer": "^19.2.4"
  },
  "jest": {
    "transformIgnorePatterns": [
      "node_modules/(?!wouter)/"
    ]
  },
  "publishConfig": {
    "access": "public"
  }
}
